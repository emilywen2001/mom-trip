# 拷贝为 .env 并填入真实值；不要把真实密钥提交到这个模板里！
# cp .env.example .env

# GLM API（通过 Anthropic 兼容接口）
# 申请地址：https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
GLM_MODEL=GLM-5.1

# 天气 (OpenWeatherMap 免费版)
# 申请地址：https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# 数据库
DATABASE_URL=sqlite:///./dev.db

# 文件存储
UPLOAD_DIR=./uploads

# 豆包语音（火山引擎 v3 协议 - 不要把 key 放到前端）
# 控制台：https://console.volcengine.com/speech/app
# 同一个鉴权 APP ID 和 ACCESS_TOKEN，ASR 和 TTS 各有自己的 Resource ID
DOUBAO_APP_ID=your_doubao_app_id
DOUBAO_ACCESS_TOKEN=your_doubao_access_token

# ASR：录音文件识别 2.0
# Resource ID 必须从控制台「实例详情 → 接入指南」里精确复制，不能猜
DOUBAO_ASR_RESOURCE_ID=
DOUBAO_ASR_MODEL=bigmodel

# TTS：SeedTTS 2.0
DOUBAO_TTS_RESOURCE_ID=
# 妈妈受众建议温柔女声：zh_female_qingxin / zh_female_wenrou
DOUBAO_TTS_VOICE=zh_female_qingxin
DOUBAO_TTS_SPEED=0.95
